{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Unity Catalog",
  "theme": "luma",
  "colors": {
    "primary": "#FFBC00",
    "light": "#FFBC00",
    "dark": "#FFBC00"
  },
  "favicon": "/favicon.png",
  "logo": {
    "light": "/light.svg",
    "dark": "/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/unitycatalog/unitycatalog"
    }
  },
  "fonts": {
    "heading": {
      "family": "Plus Jakarta Sans",
      "weight": 700
    },
    "body": {
      "family": "Plus Jakarta Sans",
      "weight": 400
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/unitycatalog/unitycatalog",
      "website": "https://www.unitycatalog.io"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Home",
        "pages": ["index"]
      },
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["introduction", "quickstart", "architecture"]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/catalogs",
              "concepts/schemas",
              "concepts/tables",
              "concepts/volumes",
              "concepts/functions",
              "concepts/models"
            ]
          },
          {
            "group": "CLI Usage",
            "pages": [
              "cli/overview",
              "cli/catalogs",
              "cli/schemas",
              "cli/tables",
              "cli/volumes",
              "cli/functions",
              "cli/models"
            ]
          },
          {
            "group": "Server",
            "pages": [
              "server/installation",
              "server/configuration",
              "server/deployment",
              "server/docker",
              "server/authentication"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/overview",
              "integrations/duckdb",
              "integrations/spark",
              "integrations/trino",
              "integrations/daft",
              "integrations/xtable"
            ]
          }
        ]
      },
      {
        "tab": "AI & ML",
        "groups": [
          {
            "group": "Overview",
            "pages": ["ai/introduction", "ai/quickstart"]
          },
          {
            "group": "Client & SDK",
            "pages": [
              "ai/client-setup",
              "ai/function-calling",
              "ai/model-registry"
            ]
          },
          {
            "group": "Framework Integrations",
            "pages": [
              "ai/integrations/langchain",
              "ai/integrations/llamaindex",
              "ai/integrations/openai",
              "ai/integrations/anthropic",
              "ai/integrations/dspy",
              "ai/integrations/autogen",
              "ai/integrations/crewai"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "SDKs",
            "pages": ["api/overview", "api/python-sdk", "api/java-sdk"]
          },
          {
            "group": "REST API",
            "pages": [
              "api/rest/authentication",
              "api/rest/metastore",
              "api/rest/catalogs",
              "api/rest/schemas",
              "api/rest/tables",
              "api/rest/volumes",
              "api/rest/functions",
              "api/rest/models",
              "api/rest/permissions",
              "api/rest/credentials",
              "api/rest/storage-credentials",
              "api/rest/external-locations"
            ]
          }
        ]
      },
      {
        "tab": "Developers",
        "groups": [
          {
            "group": "Contributing",
            "pages": [
              "developers/contributing",
              "developers/building",
              "developers/testing",
              "developers/code-style"
            ]
          },
          {
            "group": "Reference",
            "pages": ["developers/roadmap", "developers/changelog"]
          }
        ]
      }
    ]
  },
  "seo": {
    "metatags": {
      "robots": "noindex"
    }
  }
}
